{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "hono",
  "outputDirectory": "src",
  "functions": {
    "**/*": {
      "includeFiles": "src/templates/**"
    }
  },
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/favicon.png"
    }
  ],
  "github": {
    "silent": true
  }
}
